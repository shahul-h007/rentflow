generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  MEMBER
}
enum MonthStatus {
  OPEN
  CLOSED
  ARCHIVED
}
enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  WAIVED
  BORROWED
  TRANSFERRED
  CANCELLED
  REFUNDED
}
enum SplitType {
  EQUAL
  PERCENTAGE
  FIXED
  SELECTED
  CUSTOM
}
enum DebtStatus {
  OPEN
  SETTLED
  CANCELLED
}

model User {
  id String @id @default(uuid())
  authId String @unique @map("auth_id")
  email String @unique
  role Role @default(MEMBER)
  member Member?
  lastLoginAt DateTime? @map("last_login_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("users")
}

model Member {
  id String @id @default(uuid())
  userId String? @unique @map("user_id")
  name String
  email String? @unique
  phone String?
  photoUrl String? @map("photo_url")
  joinedAt DateTime @default(now()) @map("joined_at")
  active Boolean @default(true)
  houseId String? @map("house_id")
  house House? @relation(fields:[houseId],references:[id])
  user User? @relation(fields:[userId],references:[id])
  rentPayments RentPayment[]
  utilityPayments UtilityPayment[]
  utilitiesPaid Utility[] @relation("utility_paid_by")
  expenses Expense[]
  expenseSplits ExpenseSplit[]
  debtors Debt[] @relation("debtor")
  creditors Debt[] @relation("creditor")
  rentTransactions RentPaymentTransaction[] @relation("rent_transaction_payer")
  @@index([active])
  @@map("members")
}

model Month {
  id String @id @default(uuid())
  startsOn DateTime @map("starts_on")
  endsOn DateTime @map("ends_on")
  rent Int
  status MonthStatus @default(OPEN)
  closedAt DateTime? @map("closed_at")
  houseId String? @map("house_id")
  house House? @relation(fields:[houseId],references:[id])
  rentPayments RentPayment[]
  utilities Utility[]
  expenses Expense[]
  @@index([status])
  @@unique([houseId, startsOn])
  @@map("months")
}

model RentPayment {
  id String @id @default(uuid())
  monthId String @map("month_id")
  memberId String @map("member_id")
  amountDue Int @map("amount_due")
  amountPaid Int @default(0) @map("amount_paid")
  carryForward Int @default(0) @map("carry_forward")
  status PaymentStatus @default(PENDING)
  method String?
  reference String?
  paidAt DateTime? @map("paid_at")
  month Month @relation(fields:[monthId],references:[id],onDelete:Cascade)
  member Member @relation(fields:[memberId],references:[id])
  transactions RentPaymentTransaction[]
  @@unique([monthId,memberId])
  @@index([memberId,status])
  @@map("rent_payments")
}

model Utility {
  id String @id @default(uuid())
  monthId String @map("month_id")
  name String
  amount Int
  paidById String? @map("paid_by_id")
  splitType SplitType @default(EQUAL) @map("split_type")
  dueDate DateTime? @map("due_date")
  paidAt DateTime? @map("paid_at")
  status PaymentStatus @default(PENDING)
  attachmentUrl String? @map("attachment_url")
  createdAt DateTime @default(now()) @map("created_at")
  month Month @relation(fields:[monthId],references:[id],onDelete:Cascade)
  paidBy Member? @relation("utility_paid_by",fields:[paidById],references:[id])
  payments UtilityPayment[]
  @@index([monthId,status])
  @@map("utilities")
}

model UtilityPayment {
  id String @id @default(uuid())
  utilityId String @map("utility_id")
  memberId String @map("member_id")
  amountDue Int @map("amount_due")
  amountPaid Int @default(0) @map("amount_paid")
  status PaymentStatus @default(PENDING)
  utility Utility @relation(fields:[utilityId],references:[id],onDelete:Cascade)
  member Member @relation(fields:[memberId],references:[id])
  @@unique([utilityId,memberId])
  @@map("utility_payments")
}

model Expense {
  id String @id @default(uuid())
  monthId String @map("month_id")
  paidById String @map("paid_by_id")
  title String
  amount Int
  splitType SplitType @default(EQUAL) @map("split_type")
  notes String?
  receiptUrl String? @map("receipt_url")
  createdAt DateTime @default(now()) @map("created_at")
  month Month @relation(fields:[monthId],references:[id])
  paidBy Member @relation(fields:[paidById],references:[id])
  splits ExpenseSplit[]
  @@index([monthId])
  @@map("expenses")
}

model ExpenseSplit {
  id String @id @default(uuid())
  expenseId String @map("expense_id")
  memberId String @map("member_id")
  amount Int
  expense Expense @relation(fields:[expenseId],references:[id],onDelete:Cascade)
  member Member @relation(fields:[memberId],references:[id])
  @@unique([expenseId,memberId])
  @@map("expense_splits")
}

model Debt {
  id String @id @default(uuid())
  debtorId String @map("debtor_id")
  creditorId String @map("creditor_id")
  amount Int
  settledAmount Int @default(0) @map("settled_amount")
  reason String
  createdAt DateTime @default(now()) @map("created_at")
  settledAt DateTime? @map("settled_at")
  status DebtStatus @default(OPEN)
  debtor Member @relation("debtor",fields:[debtorId],references:[id])
  creditor Member @relation("creditor",fields:[creditorId],references:[id])
  @@index([debtorId,status])
  @@map("debts")
}

model Setting {
  id String @id @default(uuid())
  key String @unique
  value Json
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("settings")
}

model ActivityLog {
  id String @id @default(uuid())
  actorId String? @map("actor_id")
  entity String
  entityId String @map("entity_id")
  action String
  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")
  @@index([entity,entityId])
  @@map("activity_logs")
}

model House {
  id String @id @default(uuid())
  name String
  rent Int
  dueDate Int @default(5) @map("due_date")
  currency String @default("INR")
  upiId String? @map("upi_id")
  ownerName String? @map("owner_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  members Member[]
  months Month[]
  @@map("houses")
}

model RentPaymentTransaction {
  id String @id @default(uuid())
  rentPaymentId String @map("rent_payment_id")
  amount Int
  method String
  reference String?
  screenshotUrl String? @map("screenshot_url")
  status String @default("SUBMITTED") // SUBMITTED, CONFIRMED, REJECTED
  paidAt DateTime @default(now()) @map("paid_at")
  verifiedAt DateTime? @map("verified_at")
  payerId String? @map("payer_id")
  payer Member? @relation("rent_transaction_payer", fields:[payerId], references:[id])
  rentPayment RentPayment @relation(fields:[rentPaymentId],references:[id],onDelete:Cascade)
  @@map("rent_payment_transactions")
}

model Notification {
  id String @id @default(uuid())
  memberId String? @map("member_id")
  title String
  message String
  type String // RENT_DUE, PAYMENT_CONFIRMED, SYSTEM
  isRead Boolean @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([memberId, isRead])
  @@map("notifications")
}
